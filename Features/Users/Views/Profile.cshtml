@model Carvia.Features.Users.DetailedUserViewModel
@{
  ViewData["Title"] = "User Profile Terminal";
  ViewData["IsHeroPage"] = false;
}

<main class="flex-grow flex justify-center w-full max-w-[1440px] mx-auto px-6 pt-28 pb-20 text-left">
  <div class="w-full max-w-2xl">

    <div class="mb-8 border-b border-outline-variant/30 pb-6">
      <h2 class="font-mono text-[11px] font-bold text-acid-mint uppercase tracking-[1.9px] mb-2">
        Account Hub
      </h2>
      <h1 class="font-display text-5xl font-black text-white uppercase tracking-tighter leading-none">
        Profile Overview
      </h1>
    </div>

    <div class="space-y-8">

      <div class="border border-outline-variant/50 rounded-[40px] p-8 md:p-10 bg-surface-container">
        <h3 class="font-display text-xl font-bold text-white mb-6 border-b border-outline-variant/30 pb-3 uppercase tracking-tight">
          Identity Credentials
        </h3>

        <div class="space-y-4 font-mono text-xs uppercase tracking-wider">
          <div class="flex justify-between items-center py-3 border-b border-outline-variant/20">
            <span class="text-on-surface-variant">Username</span>
            <span class="text-white font-bold normal-case font-body text-sm">@Model.Username</span>
          </div>

          <div class="flex justify-between items-center py-3">
            <span class="text-on-surface-variant">Email Address</span>
            <span class="text-white font-bold normal-case font-body text-sm">@Model.Email</span>
          </div>
        </div>
      </div>

      <div class="border border-outline-variant/50 rounded-[40px] p-8 md:p-10 bg-surface-container">
        <h3 class="font-display text-xl font-bold text-white mb-6 border-b border-outline-variant/30 pb-3 uppercase tracking-tight">
          Registry Activity
        </h3>

        <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-6">
          <div>
            <p class="font-mono text-[11px] font-bold text-on-surface-variant uppercase tracking-widest mb-1">Curated Visions</p>
            <p class="font-display text-4xl font-black text-white">@Model.CuratorItemCount</p>
          </div>

          <a asp-controller="CuratorItems" asp-action="Index"
             class="bg-transparent border border-white/20 text-white font-mono text-[11px] font-bold uppercase py-3 px-6 rounded-full hover:border-acid-mint hover:text-acid-mint transition-colors text-center self-start sm:self-auto tracking-wider">
            Launch Curator Dashboard
          </a>
        </div>
      </div>

      <div class="flex justify-end pt-4">
        <a asp-action="Edit"
           class="bg-transparent border border-acid-mint text-acid-mint font-mono text-xs font-bold uppercase tracking-widest rounded-full py-4 px-12 hover:bg-acid-mint hover:text-background transition-all duration-300 shadow-[0_0_30px_rgba(60,255,208,0.05)]">
          Manage Account Settings
        </a>
      </div>

    </div>
  </div>
</main>