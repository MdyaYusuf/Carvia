@model Carvia.Features.Users.UpdateUserViewModel
@{
  ViewData["Title"] = "Account Settings";
  ViewData["IsHeroPage"] = false;
}

<main class="flex-grow flex justify-center w-full max-w-[1440px] mx-auto px-6 pt-28 pb-20 text-left">
  <div class="w-full max-w-2xl">

    <div class="mb-8 border-b border-outline-variant/30 pb-6">
      <h1 class="font-display text-5xl font-black text-white uppercase tracking-tighter leading-none">
        PROFILE SETTINGS
      </h1>
    </div>

    <form asp-action="Edit" method="post" class="space-y-8">
      @Html.AntiForgeryToken()
      <input type="hidden" asp-for="Id" />

      @if (!ViewData.ModelState.IsValid)
      {
        <div asp-validation-summary="ModelOnly" class="text-error font-mono text-xs uppercase tracking-wide bg-error-container/10 border border-error-container p-4 rounded-sm mb-6"></div>
      }

      <div class="border border-outline-variant/50 rounded-[40px] p-8 md:p-10 bg-surface-container">
        <h3 class="font-display text-xl font-bold text-white mb-6 border-b border-outline-variant/30 pb-3 uppercase tracking-tight">
          Account Details
        </h3>

        <div class="space-y-6">
          <div class="flex flex-col">
            <label asp-for="Username" class="font-mono text-[11px] font-bold text-on-surface-variant uppercase tracking-widest mb-2">Username</label>
            <input asp-for="Username" autocomplete="username" class="bg-background border border-outline-variant text-white focus:border-acid-mint focus:ring-0 rounded-[2px] p-4 font-body text-sm h-14 outline-none transition-colors" />
            <span asp-validation-for="Username" class="text-error font-mono text-[10px] uppercase mt-1"></span>
          </div>

          <div class="flex flex-col">
            <label asp-for="Email" class="font-mono text-[11px] font-bold text-on-surface-variant uppercase tracking-widest mb-2">Email Address</label>
            <input asp-for="Email" autocomplete="email" class="bg-background border border-outline-variant text-white focus:border-acid-mint focus:ring-0 rounded-[2px] p-4 font-body text-sm h-14 outline-none transition-colors" />
            <span asp-validation-for="Email" class="text-error font-mono text-[10px] uppercase mt-1"></span>
          </div>
        </div>
      </div>

      <div class="border border-outline-variant/50 rounded-[40px] p-8 md:p-10 bg-surface-container">
        <h3 class="font-display text-xl font-bold text-white mb-6 border-b border-outline-variant/30 pb-3 uppercase tracking-tight">
          Security Update
        </h3>

        <div class="space-y-6">
          <div class="flex flex-col">
            <label asp-for="CurrentPassword" class="font-mono text-[11px] font-bold text-on-surface-variant uppercase tracking-widest mb-2">Current Password</label>
            <input asp-for="CurrentPassword" type="password" placeholder="••••••••" autocomplete="current-password" class="bg-background border border-outline-variant text-white focus:border-acid-mint focus:ring-0 rounded-[2px] p-4 font-body text-sm h-14 outline-none transition-colors" />
            <span asp-validation-for="CurrentPassword" class="text-error font-mono text-[10px] uppercase mt-1"></span>
          </div>

          <div class="h-px w-full bg-outline-variant/20 my-2"></div>

          <div class="flex flex-col">
            <label asp-for="NewPassword" class="font-mono text-[11px] font-bold text-on-surface-variant uppercase tracking-widest mb-2">New Password</label>
            <input asp-for="NewPassword" type="password" autocomplete="new-password" class="bg-background border border-outline-variant text-white focus:border-acid-mint focus:ring-0 rounded-[2px] p-4 font-body text-sm h-14 outline-none transition-colors" />
            <p class="font-body text-[11px] text-outline-variant mt-1">Must contain minimum 12 characters matching database security rules.</p>
            <span asp-validation-for="NewPassword" class="text-error font-mono text-[10px] uppercase mt-1"></span>
          </div>

          <div class="flex flex-col">
            <label asp-for="ConfirmNewPassword" class="font-mono text-[11px] font-bold text-on-surface-variant uppercase tracking-widest mb-2">Confirm New Password</label>
            <input asp-for="ConfirmNewPassword" type="password" autocomplete="new-password" class="bg-background border border-outline-variant text-white focus:border-acid-mint focus:ring-0 rounded-[2px] p-4 font-body text-sm h-14 outline-none transition-colors" />
            <span asp-validation-for="ConfirmNewPassword" class="text-error font-mono text-[10px] uppercase mt-1"></span>
          </div>
        </div>
      </div>

      <div class="flex justify-end items-center gap-6 pt-4">
        <a asp-action="Profile" class="font-mono text-xs font-bold uppercase tracking-widest text-on-surface-variant hover:text-white transition-colors py-4 px-6">
          Cancel
        </a>
        <button type="submit" class="bg-transparent border border-acid-mint text-acid-mint font-mono text-xs font-bold uppercase tracking-widest rounded-full py-4 px-12 hover:bg-acid-mint hover:text-background transition-all duration-300">
          Save Changes
        </button>
      </div>

    </form>
  </div>
</main>