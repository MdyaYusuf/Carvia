<!-- TopAppBar -->
<nav class="fixed top-0 w-full z-50 bg-background/80 backdrop-blur-md flex justify-between items-center px-12 py-8 border-b border-outline-variant/30">
  <a asp-controller="Cars" asp-action="Index" class="text-4xl font-black text-white tracking-tighter hover:text-acid-mint transition-colors font-display">
    MANUKA
  </a>

  <div class="hidden md:flex space-x-8">
    <a class="font-mono text-[11px] font-bold text-white opacity-80 hover:opacity-100 hover:text-acid-mint transition-all tracking-[1.9px]" asp-controller="Cars" asp-action="Showcase">SHOWCASE</a>
    <a class="font-mono text-[11px] font-bold text-white opacity-80 hover:opacity-100 hover:text-acid-mint transition-all tracking-[1.9px]" asp-controller="Cars" asp-action="Index">TIMELINE</a>
    <a class="font-mono text-[11px] font-bold text-white opacity-80 hover:opacity-100 hover:text-acid-mint transition-all tracking-[1.9px]" href="#">JOURNAL</a>
  </div>

  <div class="flex items-center gap-6">
    @if (User.Identity?.IsAuthenticated == true)
    {
      <a asp-controller="Users" asp-action="Profile" class="font-mono text-[11px] font-bold text-white hover:text-acid-mint tracking-[1.9px]">PROFILE</a>
      <form asp-controller="Account" asp-action="Logout" method="post" class="inline">
        <button type="submit" class="font-mono text-[11px] font-bold text-error hover:opacity-80 tracking-[1.9px]">LOGOUT</button>
      </form>
    }
    else
    {
      <a asp-controller="Authentication" asp-action="Login" class="font-mono text-[11px] font-bold text-white hover:text-acid-mint tracking-[1.9px]">LOGIN</a>
      <a asp-controller="Authentication" asp-action="Register" class="font-mono text-[11px] font-bold text-acid-mint border border-acid-mint rounded-full px-6 py-2 hover:bg-acid-mint hover:text-background transition-all tracking-[1.9px]">
        JOIN
      </a>
    }
  </div>
</nav>