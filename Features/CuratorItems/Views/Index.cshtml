@using Carvia.Features.CuratorItems
@model IEnumerable<ShowcaseCuratorItemViewModel>
@{
  ViewData["Title"] = "Curator Mode - Archives";
  ViewData["IsHeroPage"] = false;
}

<div class="mb-12 border-b border-outline-variant/30 pb-6">
  <h2 class="font-mono text-[11px] font-bold text-acid-mint uppercase tracking-[1.9px] mb-2">
    Your Saved Visions
  </h2>
  <h1 class="font-display text-5xl md:text-6xl font-black text-white uppercase tracking-tighter leading-none">
    Curator Mode
  </h1>
</div>

<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
  @foreach (var item in Model)
  {
    bool isVision = item.CarModel.Contains("Vision") || item.CarModel.Contains("Prototype");

    <div class="group relative rounded-[40px] border @(isVision ? "border-acid-mint bg-acid-mint" : "border-outline-variant bg-surface") transition-colors duration-300 overflow-hidden flex flex-col">

      @if (isVision)
      {
        <div class="absolute top-6 right-6 z-10 flex flex-col gap-1">
          <div class="w-1 h-8 bg-background"></div>
          <div class="w-1 h-4 bg-background"></div>
        </div>
      }

      <div class="p-1 border-b @(isVision ? "border-background/20" : "border-outline-variant")">
        <div class="relative w-full aspect-video rounded-[4px] border @(isVision ? "border-background/20" : "border-outline-variant") overflow-hidden">
          <img src="@item.CarImageUrl" alt="@item.CarMake"
               class="w-full h-full object-cover @(isVision ? "mix-blend-multiply opacity-90" : "")" />
        </div>
      </div>

      <div class="p-8 flex flex-col flex-grow @(isVision ? "text-background" : "text-white")">
        <span class="font-mono text-[10px] uppercase tracking-widest opacity-60 mb-1">@item.CarMake</span>
        <h3 class="font-display text-2xl font-black uppercase tracking-tight">
          @item.CarModel
        </h3>

        @if (!string.IsNullOrEmpty(item.UserNote))
        {
          <p class="font-body text-xs mt-4 mb-2 opacity-80 line-clamp-3 italic leading-relaxed">
            "@item.UserNote"
          </p>
        }
        else
        {
          <p class="font-body text-xs mt-4 mb-2 opacity-40 line-clamp-3 italic leading-relaxed">
            No commentary logged for this structural configuration.
          </p>
        }

        <div class="h-px w-full @(isVision ? "bg-background/20" : "bg-outline-variant/30") mt-auto mb-6"></div>

        <div class="flex flex-col gap-3">
          <div class="flex gap-4">
            <a asp-controller="Cars" asp-action="Details" asp-route-id="@item.CarId"
               class="flex-1 py-3 px-4 rounded-full border @(isVision ? "border-background text-background hover:bg-background hover:text-acid-mint" : "border-white text-white hover:bg-white hover:text-background") font-mono text-[10px] font-bold uppercase text-center transition-colors tracking-widest">
              View Specs
            </a>

            <a asp-action="Edit" asp-route-id="@item.Id"
               class="flex-1 py-3 px-4 rounded-full border @(isVision ? "border-background text-background hover:bg-background hover:text-acid-mint" : "border-outline text-outline hover:border-acid-mint hover:text-acid-mint") font-mono text-[10px] font-bold uppercase text-center transition-colors tracking-widest">
              Edit Note
            </a>
          </div>

          <form asp-action="Delete" asp-route-id="@item.Id" method="post" class="w-full" onsubmit="return confirm('Remove this vision from your curated list?');">
            @Html.AntiForgeryToken()
            <button type="submit"
                    class="w-full py-3 px-4 rounded-full border @(isVision ? "border-background/40 text-background/70 hover:border-background hover:text-background" : "border-secondary-container text-secondary-container hover:bg-secondary-container hover:text-white") font-mono text-[10px] font-bold uppercase transition-colors tracking-widest text-center">
              Remove Entry
            </button>
          </form>
        </div>
      </div>
    </div>
  }
</div>