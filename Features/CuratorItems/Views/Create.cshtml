@using Carvia.Features.CuratorItems
@model CreateCuratorItemViewModel
@{
  ViewData["Title"] = "Collect Vision";
}

<div class="max-w-[640px] mx-auto py-20 px-6">
  <div class="flex items-center gap-4 mb-12">
    <div class="w-1 h-8 bg-acid-mint"></div>
    <h1 class="font-display text-4xl font-extrabold text-white uppercase tracking-tighter">
      Curate Registry Entry
    </h1>
  </div>

  <form asp-action="Create" method="post" class="flex flex-col gap-8 text-left">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="CarId" />
    <input type="hidden" asp-for="UserId" />

    <div class="flex flex-col gap-3">
      <label asp-for="UserNote" class="font-mono text-[11px] font-bold text-outline-variant uppercase tracking-[1.9px]">
        Technical Commentary / Narrative Notes (Optional)
      </label>
      <textarea asp-for="UserNote" rows="6"
                class="bg-surface border border-white/20 rounded-[2px] p-4 text-white focus:border-acid-mint focus:ring-0 font-body text-sm resize-none"
                placeholder="Log layout analysis details or technical performance notes regarding this collected vision structure..."></textarea>
      <span asp-validation-for="UserNote" class="text-error font-mono text-[10px] uppercase"></span>
    </div>

    <div class="flex flex-col gap-4 mt-4">
      <button type="submit" class="w-full bg-acid-mint text-background font-mono text-[12px] font-bold uppercase py-6 rounded-full hover:bg-transparent hover:text-acid-mint border border-acid-mint transition-all tracking-[2.5px] shadow-[0_0_40px_rgba(60,255,208,0.1)]">
        COMMIT TO ARCHIVES
      </button>

      <a asp-controller="Cars" asp-action="Showcase"
         class="w-full bg-transparent border border-outline-variant text-outline font-mono text-[11px] font-bold uppercase py-5 rounded-full hover:border-white hover:text-white transition-all tracking-[2px] text-center">
        ABANDON SELECTION
      </a>
    </div>
  </form>
</div>