@model List<ShowcaseCarViewModel>
@{
  ViewData["Title"] = "Bringing Visions into Reality";
  ViewData["IsHeroPage"] = true;
}

<main class="relative w-full h-screen flex flex-col justify-start pt-48 px-12 z-0 group">
  @* Static Background Handler *@
  <div class="absolute inset-0 z-[-1] border border-outline-variant bg-cover bg-center bg-no-repeat"
       style="background-image: url('/images/hero-landing.png');">
    
    <div class="absolute inset-0 bg-gradient-to-br from-background/80 via-transparent to-transparent opacity-90"></div>
  </div>

  <div class="max-w-[1440px] mx-auto w-full z-10 flex flex-col items-start gap-4">
    <div class="flex items-center gap-3">
      <div class="w-1 h-1 bg-acid-mint rounded-sm"></div>
      <p class="font-mono text-[10px] font-bold text-acid-mint uppercase tracking-[2.5px]">
        A NEW ERA OF ENGINEERING
      </p>
    </div>
    
    @* Smaller, top-aligned typography *@
    <h1 class="font-display text-7xl md:text-[80px] font-extrabold text-white max-w-2xl leading-[0.9] tracking-tighter uppercase">
      Bringing visions<br />into reality.
    </h1>

    <div class="mt-10">
      <a asp-action="Showcase"
         class="rounded-full border border-acid-mint px-10 py-4 font-mono text-[11px] font-bold text-acid-mint hover:bg-acid-mint hover:text-background transition-all duration-300 tracking-[2px] inline-block text-center shadow-[0_0_30px_rgba(60,255,208,0.1)]">
        EXPLORE SHOWCASE
      </a>
    </div>
  </div>
</main>