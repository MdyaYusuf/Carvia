@model DetailedCarViewModel
@{
  ViewData["Title"] = $"{Model.Make} {Model.Model} - Specs";
  ViewData["IsHeroPage"] = true; // Hero section bleeds to edges
}

<!-- Hero Section -->
<header class="relative w-full h-[819px] flex items-end pb-24 px-12 mt-24">
  <div class="absolute inset-0 z-0">
    <img src="@Model.MainImageUrl"
         alt="@Model.Make @Model.Model"
         class="w-full h-full object-cover object-center border border-outline-variant rounded" />
    <div class="absolute inset-0 bg-gradient-to-t from-background to-transparent opacity-90"></div>
  </div>
    
  <div class="relative z-10 flex flex-col gap-6 max-w-[800px]">
    <div class="flex items-center gap-4">
      <!-- 4px Hazard Strike -->
      <div class="w-1 h-8 bg-acid-mint"></div>
      <span class="font-mono text-[11px] font-bold text-acid-mint uppercase tracking-[1.9px]">
        Live Specs . Unveiled
      </span>
    </div>
    <h1 class="font-display text-[107px] font-extrabold text-white leading-[100px] tracking-tighter uppercase">
      @Model.Model
    </h1>
    <p class="font-body text-lg font-light text-on-surface-variant max-w-2xl">
      @Model.Description
    </p>
  </div>
</header>

<!-- Performance Specs Section -->
<section class="w-full px-12 py-20 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4 max-w-[1440px] mx-auto">
  <!-- Pricing / Output Tile -->
  <div class="border border-outline-variant p-8 flex flex-col gap-4 bg-background group hover:border-acid-mint transition-colors relative overflow-hidden">
    <span class="font-mono text-[11px] font-bold text-outline uppercase tracking-[1.9px]">Market Value</span>
    <span class="font-display text-[40px] leading-none font-bold text-white tracking-tighter">
      @Model.Price.ToString("C0")
    </span>
    <div class="w-full h-[1px] bg-outline-variant mt-auto"></div>
  </div>

  <!-- Placeholder Tech Spec: Acceleration -->
  <div class="border border-outline-variant p-8 flex flex-col gap-4 bg-background group hover:border-acid-mint transition-colors relative overflow-hidden">
    <span class="font-mono text-[11px] font-bold text-outline uppercase tracking-[1.9px]">Year of Release</span>
    <span class="font-display text-[40px] leading-none font-bold text-white tracking-tighter">@Model.Year</span>
    <div class="w-full h-[1px] bg-outline-variant mt-auto"></div>
  </div>

  <!-- Category Context -->
  <div class="border border-outline-variant p-8 flex flex-col gap-4 bg-background group hover:border-acid-mint transition-colors relative overflow-hidden">
    <span class="font-mono text-[11px] font-bold text-outline uppercase tracking-[1.9px]">Classification</span>
    <span class="font-display text-[40px] leading-none font-bold text-white tracking-tighter uppercase">@Model.CategoryName</span>
    <div class="w-full h-[1px] bg-outline-variant mt-auto"></div>
  </div>

  <!-- Status Flag -->
  <div class="border border-outline-variant p-8 flex flex-col gap-4 bg-background group hover:border-acid-mint transition-colors relative overflow-hidden">
    <span class="font-mono text-[11px] font-bold text-outline uppercase tracking-[1.9px]">Status</span>
    <span class="font-display text-[40px] leading-none font-bold text-white tracking-tighter uppercase">Available</span>
    <div class="w-full h-[1px] bg-outline-variant mt-auto"></div>
  </div>
</section>

<!-- Precision Gallery -->
<section class="w-full px-12 py-20 max-w-[1440px] mx-auto">
  <div class="flex items-center gap-4 mb-12">
    <div class="w-1 h-6 bg-acid-mint"></div>
    <h2 class="font-display text-3xl font-bold text-white uppercase tracking-tight">Precision Details</h2>
  </div>
    
  <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
    @foreach (var imageUrl in Model.GalleryUrls)
    {
      <div class="aspect-video relative rounded overflow-hidden border border-outline-variant group">
        <img src="@imageUrl"
             class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
             alt="Technical Detail View" />
      </div>
    }
  </div>
</section>

<!-- Call to Action -->
<section class="w-full px-12 py-24 flex justify-center items-center">
  <button class="bg-transparent border border-acid-mint text-acid-mint font-mono text-[12px] font-bold uppercase px-12 py-6 rounded-full hover:bg-acid-mint hover:text-background transition-colors tracking-[1.5px] w-full md:w-auto">
    ENQUIRE ABOUT THIS VISION
  </button>
</section>