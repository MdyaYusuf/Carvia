@model DetailedCarViewModel
@{
  ViewData["Title"] = $"{Model.Make} {Model.Model} - Specs";
  ViewData["IsHeroPage"] = true;
}

<header class="relative w-full h-[70vh] flex items-end pb-24 px-12 mt-24">
  <div class="absolute inset-0 z-0">
    <img src="@Model.MainImageUrl"
         alt="@Model.Make @Model.Model"
         class="w-full h-full object-cover object-center border border-outline-variant rounded" />
    <div class="absolute inset-0 bg-gradient-to-t from-background to-transparent opacity-90"></div>
  </div>

  <div class="relative z-10 flex flex-col gap-6 max-w-[800px]">
    <div class="flex items-center gap-4">
      <div class="w-1 h-8 bg-acid-mint"></div>
      <span class="font-mono text-[11px] font-bold text-acid-mint uppercase tracking-[1.9px]">
        Live Specs
      </span>
    </div>
    <h1 class="font-display text-[107px] font-extrabold text-white leading-[100px] tracking-tighter uppercase">
      @Model.Model
    </h1>
    <p class="font-body text-lg font-light text-on-surface-variant max-w-2xl">
      @Model.Description
    </p>
  </div>
</header>

<section class="w-full px-12 py-20 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4 max-w-[1440px] mx-auto">
  <div class="border border-outline-variant p-8 flex flex-col gap-4 bg-background group hover:border-acid-mint transition-colors relative overflow-hidden">
    <span class="font-mono text-[11px] font-bold text-outline uppercase tracking-[1.9px]">Market Value</span>
    <span class="font-display text-[40px] leading-none font-bold text-white tracking-tighter">
      @Model.Price.ToString("C0")
    </span>
    <div class="w-full h-[1px] bg-outline-variant mt-auto"></div>
  </div>

  <div class="border border-outline-variant p-8 flex flex-col gap-4 bg-background group hover:border-acid-mint transition-colors relative overflow-hidden">
    <span class="font-mono text-[11px] font-bold text-outline uppercase tracking-[1.9px]">Year of Release</span>
    <span class="font-display text-[40px] leading-none font-bold text-white tracking-tighter">@Model.Year</span>
    <div class="w-full h-[1px] bg-outline-variant mt-auto"></div>
  </div>

  <div class="border border-outline-variant p-8 flex flex-col gap-4 bg-background group hover:border-acid-mint transition-colors relative overflow-hidden">
    <span class="font-mono text-[11px] font-bold text-outline uppercase tracking-[1.9px]">Classification</span>
    <span class="font-display text-[40px] leading-none font-bold text-white tracking-tighter uppercase">@Model.CategoryName</span>
    <div class="w-full h-[1px] bg-outline-variant mt-auto"></div>
  </div>

  <div class="border border-outline-variant p-8 flex flex-col gap-4 bg-background group hover:border-acid-mint transition-colors relative overflow-hidden">
    <span class="font-mono text-[11px] font-bold text-outline uppercase tracking-[1.9px]">Status</span>
    <span class="font-display text-[40px] leading-none font-bold text-white tracking-tighter uppercase">Available</span>
    <div class="w-full h-[1px] bg-outline-variant mt-auto"></div>
  </div>
</section>

<section class="w-full px-12 py-10 flex justify-center gap-6 border-t border-b border-outline-variant/10">
  @if (User.IsInRole("Admin"))
  {
    <button onclick="openEditModal('@Model.Id')"
            class="bg-transparent border border-acid-mint text-acid-mint font-mono text-[12px] font-bold uppercase px-16 py-5 rounded-full hover:bg-acid-mint hover:text-background transition-all tracking-[2px]">
      Edit Car Specifications
    </button>
  }

  <a asp-controller="CuratorItems" asp-action="Create" asp-route-carId="@Model.Id"
     class="bg-acid-mint text-background border border-acid-mint font-mono text-[12px] font-bold uppercase px-16 py-5 rounded-full hover:bg-transparent hover:text-acid-mint transition-all tracking-[2px]">
    Collect to Curator Mode
  </a>
</section>

<section class="w-full px-12 py-20 max-w-[1440px] mx-auto">
  <div class="flex items-center gap-4 mb-12">
    <div class="w-1 h-6 bg-acid-mint"></div>
    <h2 class="font-display text-3xl font-bold text-white uppercase tracking-tight">Gallery</h2>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
    @foreach (var item in Model.Gallery)
    {
      <div class="aspect-video relative rounded overflow-hidden border border-outline-variant group">
        <img src="@item.Url"
             class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
             alt="Technical Detail View" />
      </div>
    }
  </div>
</section>

<section class="w-full px-12 py-24 flex flex-col gap-12 justify-center items-center border-t border-outline-variant/30">
  <div class="flex flex-col items-center gap-4">
    <span class="font-mono text-[12px] text-outline-variant uppercase tracking-[4px]">Carvia Global Registry</span>
    <p class="font-mono text-[12px] text-on-surface-variant text-center leading-relaxed">
      PHONE: +90 (555) 768-32-23 <span class="mx-4 text-outline-variant hidden md:inline">|</span> <br class="md:hidden" /> EMAIL: CONTACT@CARVIA.IO
    </p>
  </div>

  <a asp-controller="Cars" asp-action="Showcase" class="bg-transparent border border-acid-mint text-acid-mint font-mono text-[12px] font-bold uppercase px-12 py-6 rounded-full hover:bg-acid-mint hover:text-background transition-all tracking-[1.5px] text-center w-full md:w-auto shadow-[0_0_20px_rgba(60,255,208,0.05)]">
    Get Back to Showcase
  </a>
</section>

@* --- Edit Modal --- *@
<partial name="~/Features/Shared/Views/_EditCarModal.cshtml" />