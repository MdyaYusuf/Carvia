@model IEnumerable<ShowcaseCarViewModel>
@{
  ViewData["Title"] = "Car Registry";
  ViewData["IsHeroPage"] = false;
}

<div class="relative flex gap-10">
  <aside class="hidden lg:flex w-16 flex-col items-center border-r border-outline-variant pt-20 relative">
    <div class="sticky top-40 h-[calc(100vh-200px)] flex flex-col items-center">
      <div class="h-full border-l border-dashed border-outline-variant relative">
        <div class="absolute top-0 -left-[5px] w-[9px] h-[9px] rounded-full bg-acid-mint"></div>
      </div>
    </div>
  </aside>

  <div class="flex-1 space-y-12 pb-20">
    <div class="flex items-center justify-between border-b border-outline-variant pb-4 mb-8">
      <div class="flex space-x-6">
        <button class="font-label-mono text-acid-mint uppercase">All Models</button>
      </div>

      @if (User.IsInRole("Admin"))
      {
        <a asp-action="Create" class="btn-carvia-primary py-2 px-6 flex items-center gap-2">
          <span class="material-symbols-outlined text-base">add</span>
          ADD NEW CAR
        </a>
      }
    </div>

    @if (!Model.Any())
    {
      <main class="flex flex-col items-center justify-center pt-20 text-center relative">
        <div class="hazard-bar mb-12"></div>
        <h1 class="font-display-hero text-white mb-6 uppercase">YOUR COLLECTION<br />IS EMPTY</h1>
        <p class="font-body-large text-on-surface-variant max-w-xl mx-auto mb-12 text-lg">
          Start curating your high-performance garage to build your personal car registry.
        </p>

        @if (User.IsInRole("Admin"))
        {
          <a asp-action="Create" class="btn-carvia-primary uppercase">ADD FIRST CAR</a>
        }
      </main>
    }
    else
    {
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        @foreach (var car in Model)
        {
          <div onclick="navigateToDetails(event, '@Url.Action("Details", "Cars", new { id = car.Id })')"
               class="block group cursor-pointer">
            <article class="relative bg-surface-container border border-outline-variant rounded-[40px] overflow-hidden hover:border-acid-mint transition-all duration-500">
              <div class="p-6">
                <div class="border border-outline-variant rounded-lg overflow-hidden p-1 mb-6">
                  <img src="@car.ImageUrl" class="w-full aspect-video object-cover rounded-md group-hover:scale-105 transition-transform duration-700" alt="@car.Make @car.Model" />
                </div>
                <div class="px-2">
                  <p class="font-label-mono text-on-surface-variant mb-2">@car.Year • @car.Make</p>
                  <h2 class="font-display text-3xl font-extrabold text-white group-hover:text-acid-mint transition-colors mb-6 uppercase">@car.Model</h2>
                  
                  <div class="flex items-center justify-between">
                    <span class="font-label-mono text-acid-mint flex items-center gap-2">
                      VIEW SPECS <span class="material-symbols-outlined text-sm transition-transform group-hover:translate-x-1">arrow_forward</span>
                    </span>

                    @if (User.IsInRole("Admin"))
                    {
                      <button type="button"
                              onclick="event.stopPropagation(); openEditModal('@car.Id')"
                              class="font-label-mono text-[10px] text-white/40 hover:text-acid-mint uppercase tracking-[2px] transition-colors relative z-30">
                        Edit Entry
                      </button>
                    }
                  </div>
                </div>
              </div>
            </article>
          </div>
        }
      </div>
    }
  </div>
</div>

@* --- Edit Modal --- *@
<partial name="~/Features/Shared/Views/_EditCarModal.cshtml" />

@section Scripts {
  <script>
    function navigateToDetails(event, url) {
        window.location.href = url;
    }
  </script>
}